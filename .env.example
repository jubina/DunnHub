# .env.example — Copy this to .env and fill in your values
# Never commit .env — it contains live credentials

# API key for authenticating requests to the remote MCP server
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DUNNHUB_API_KEY=your_api_key_here

# Password for the OAuth2 authorization page (auth.wizardsword.page)
OAUTH_PASSWORD=your_password_here

# Secret for OAuth2 token signing
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
OAUTH_SECRET=your_secret_here
